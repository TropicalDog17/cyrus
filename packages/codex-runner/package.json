{
	"name": "cyrus-codex-runner",
	"version": "0.2.66",
	"private": true,
	"description": "OpenAI Codex runner for Cyrus, driven over the Agent Client Protocol (ACP)",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"test": "vitest",
		"test:run": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@agentclientprotocol/codex-acp": "^1.1.4",
		"@agentclientprotocol/sdk": "^1.2.1",
		"cyrus-core": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"typescript": "^5.3.3",
		"vitest": "^4.1.9"
	}
}
